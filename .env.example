# .env.example (This is safe to commit to Git)

# API Server
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO # Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)

# Ollama
OLLAMA_HOST=ollama
OLLAMA_MODEL=mistral
OLLAMA_HEALTH_TIMEOUT=5 # Timeout for Ollama health checks and model listing (seconds)
OLLAMA_GENERATE_TIMEOUT=600 # Timeout for Ollama text generation requests (seconds)

# Caching (NEW in v1.1.0)
CACHE_ENABLED=true # Enable/disable response caching (true/false)
CACHE_SIZE=100 # Maximum number of cached responses (LRU cache)

# Retry Logic (NEW in v1.1.0)
RETRY_ATTEMPTS=3 # Number of retry attempts for failed Ollama calls
RETRY_BACKOFF_FACTOR=2 # Exponential backoff multiplier (1 -> 2 -> 4 seconds)

# Web UI (if used)
WEBUI_PORT=3000
WEBUI_SECRET_KEY=your_secret_key_here # Do not write the real key here!

# GPU (if used)
NVIDIA_VISIBLE_DEVICES=all

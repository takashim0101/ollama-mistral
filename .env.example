# .env.example (This is safe to commit to Git)

# API Server
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO # Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)

# Ollama
OLLAMA_HOST=ollama
OLLAMA_MODEL=mistral
OLLAMA_HEALTH_TIMEOUT=5 # Timeout for Ollama health checks and model listing (seconds)
OLLAMA_GENERATE_TIMEOUT=600 # Timeout for Ollama text generation requests (seconds)

# Web UI (if used)
WEBUI_PORT=3000
WEBUI_SECRET_KEY=your_secret_key_here # Do not write the real key here!

# GPU (if used)
NVIDIA_VISIBLE_DEVICES=all